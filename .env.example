# Copy this file to .env on a PRODUCTION server and fill in real values.
# .env itself is gitignored on purpose — never commit real secrets.
# In development none of this is needed; config/settings/dev.py has
# safe built-in defaults.

DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=verinews.com,www.verinews.com

DB_NAME=verinews
DB_USER=verinews_user
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432
